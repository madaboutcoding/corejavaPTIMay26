package com.pti.demo;

public class App {

	public static void main(String[] args) {
		//Entry Control - while  
		int num=2;
		int i=1;
		
		while(i<11) {
			System.out.println(num+" * "+i+" = "+num*i);
			i++;
		}
		System.out.println("Reverse");
		i=10;
		while(i>0) {
			System.out.println(num+" * "+i+" = "+num*i);
			i--;
		}

	}

}
