package com.pti.demo;

public class App {

	public static void main(String[] args) {
		// Unary ++ increment by 1
		int num1=10;
		int result=num1+1;
		System.out.println("num1:="+num1);
		System.out.println("result:="+result);
		//Unary ++num1 
		result=++num1;//(num1+1)=>result=num1
		System.out.println("result:="+result);
		//Unary num1++  
	}

}
