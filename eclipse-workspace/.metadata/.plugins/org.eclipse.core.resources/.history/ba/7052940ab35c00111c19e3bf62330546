package com.pti.demo;

public class App {

	public static void main(String[] args) {
		// Swaping values of two variables using thrid variable
		int a=10;
		int b=20;
		int c=0;
		System.out.println("Before swapinng");
		System.out.println("a:"+a);
		System.out.println("b:"+b);
		System.out.println("c:"+c);
		c=a;
		a=b;
		b=c;
		System.out.println("AFter swapinng");
		System.out.println("a:"+a);
		System.out.println("b:"+b);
		System.out.println("c:"+c);

	}

}
