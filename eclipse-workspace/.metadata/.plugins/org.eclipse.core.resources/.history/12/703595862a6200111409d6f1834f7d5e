package com.pti.demo;

import com.pti.demo.model.Product;//ctrl+shift+o import



public class App {

	public static void main(String[] args) {
		// Java Class creation with Best Practice
		//Example of overloaded constructor with 3 arguments
		System.out.println("Overloaded with 3 arguments");
		Product p1=new Product(1,"Maggie",20.0);
		System.out.println(p1);
		//Example of overloaded constructor with 2 arguments
		System.out.println("Overloaded with 2 arguments");
		p1=new Product("Masala Oats",20.0);
		System.out.println(p1);
		//Example of default Constructor
		System.out.println("Default Constructor");
		p1=new Product();
		System.out.println(p1);
		
	}
	

}
