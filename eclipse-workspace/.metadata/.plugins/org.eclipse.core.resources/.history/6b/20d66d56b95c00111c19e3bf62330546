package com.pti.demo;

import java.util.Scanner;

public class App {

	public static void main(String[] args) {
		// Display the Signal colour name
		//using switch
		String colour="RED";
		try {
			System.out.println("Choose colour from below list:");
			System.out.println("1. RED");
			System.out.println("2. GREEN");
			System.out.println("3. YELLOW");
			System.out.println("ENTER COLUR NAME TO GET THE MESSAGE");
			Scanner scanner=new Scanner(System.in);
			colour=scanner.nextLine();
			switch(colour) {
			case "RED":
				System.out.println("Stop");
				break;
			case "GREEN":
				System.out.println("Go");
				break;
			case "YELLOW":
				System.out.println("Slow Down");
				break;
			default:
				System.out.println("Please enter valid colour of signal");
				break;
			}

			
			scanner.close();
		} catch (Exception e) {
			System.out.println(e.getMessage());
		}

	}

}
